rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザー情報
    match /users/{userId} {
      // 自分のユーザードキュメントのみ読み書き可能（他ユーザー名は session.displayName で十分）
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      match /subscription/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    // カメラ情報
    // read: オーナーまたはアクティブな monitorLink を持つモニターのみ（pairingCode・pushToken 漏洩防止）
    match /cameras/{cameraId} {
      allow read: if request.auth != null &&
        (resource.data.ownerUserId == request.auth.uid ||
         (exists(path('/databases/' + database + '/documents/monitorLinks/' + request.auth.uid + '_' + cameraId)) &&
          get(path('/databases/' + database + '/documents/monitorLinks/' + request.auth.uid + '_' + cameraId)).data.isActive == true));
      allow write: if request.auth != null && 
        (resource == null && request.resource.data.ownerUserId == request.auth.uid ||
         resource != null && resource.data.ownerUserId == request.auth.uid);
      
      // セッション（シグナリング）
      match /sessions/{sessionId} {
        allow create: if request.auth != null && 
          request.resource.data.monitorUserId == request.auth.uid &&
          request.resource.data.pairingCode == get(/databases/$(database)/documents/cameras/$(cameraId)).data.pairingCode;
        // read: モニター本人またはカメラオーナーのみ
        allow read: if request.auth != null &&
          (request.auth.uid == resource.data.monitorUserId ||
           request.auth.uid == get(path('/databases/' + database + '/documents/cameras/' + cameraId)).data.ownerUserId);
        allow write: if request.auth != null && 
          (request.auth.uid == resource.data.monitorUserId ||
           request.auth.uid == get(/databases/$(database)/documents/cameras/$(cameraId)).data.ownerUserId);
        
        // ICE Candidates サブコレクション
        match /iceCandidates/{candidateId} {
          allow read, write: if request.auth != null && 
            (request.auth.uid == get(/databases/$(database)/documents/cameras/$(cameraId)/sessions/$(sessionId)).data.monitorUserId ||
             request.auth.uid == get(/databases/$(database)/documents/cameras/$(cameraId)).data.ownerUserId);
        }
      }
    }
    
    // モニターリンク
    match /monitorLinks/{linkId} {
      allow create: if request.auth != null && 
        request.resource.data.monitorUserId == request.auth.uid;
      allow read, update, delete: if request.auth != null && 
        resource.data.monitorUserId == request.auth.uid;
    }
  }
}
